# --- Twilio (get from console.twilio.com; verify ALL demo phones on trial!) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...
PUBLIC_BASE_URL=            # ngrok https URL, no trailing slash

# --- Escalation targets (must be verified numbers on a trial account) ---
COORDINATOR_PHONE=+1...     # AMBER goes here
NURSE_PHONE=+1...           # RED goes here (hand this phone to a judge)

# --- Demo patient phones (repo is public — real numbers go HERE, never in
#     app/data/patients.json) ---
PATIENT_PHONE_MARGARET=+1...
PATIENT_PHONE_HAROLD=+1...

# --- LLM adapter: regex | ollama | groq | gemini_api ---
LLM_PROVIDER=regex
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b      # or a MedGemma build from Hugging Face
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile  # 8b-instant flips bare yes/no — don't downgrade
GEMINI_API_KEY=
GEMINI_MODEL=
LLM_TIMEOUT_S=1.5
